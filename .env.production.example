# Template for docker-compose.prod.yml. Copy to .env.production and fill in
# real values — .env.production is gitignored (see .gitignore's `.env.*`).
#
# Usage: docker compose -f docker-compose.prod.yml --env-file .env.production up --build

APP_NAME=FastAPI Authentication API
APP_VERSION=0.2.0
ENVIRONMENT=production

# Consumed directly by the db service in docker-compose.prod.yml; the api
# service's DATABASE_URL is assembled from these automatically.
POSTGRES_DB=fastapi_auth
POSTGRES_USER=fastapi_user
POSTGRES_PASSWORD=replace-with-a-strong-password

# Gunicorn worker count. Rule of thumb: (2 * CPU cores) + 1.
WEB_CONCURRENCY=4

# Celery worker process count (separate from Gunicorn's WEB_CONCURRENCY —
# these handle email sending, report generation, and scheduled cleanup).
CELERY_WORKER_CONCURRENCY=4

# Consumed by the nginx service (server_name + cert path) and by
# nginx/init-letsencrypt.sh (which cert to request, and the contact address
# Let's Encrypt uses for expiry warnings).
DOMAIN=api.example.com
EMAIL=admin@example.com

# openssl rand -hex 32 — must be >=32 chars and not a placeholder in production
SECRET_KEY=replace-this-with-a-long-random-secret-key

ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-google-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME=FastAPI Authentication API

# Must be https:// in production
FRONTEND_URL=https://app.example.com

CORS_ORIGINS=https://app.example.com
TRUSTED_HOSTS=api.example.com

LOG_LEVEL=INFO

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=common

# Grafana admin login (username is always "admin"). Change it after first login.
GRAFANA_ADMIN_PASSWORD=replace-with-a-strong-password

# S3-compatible object storage for file uploads. Use a real provider here
# (AWS S3, Cloudflare R2, Backblaze B2, DigitalOcean Spaces, self-hosted
# MinIO, ...) — leave S3_ENDPOINT_URL unset for real AWS.
S3_ENDPOINT_URL=
S3_BUCKET_NAME=fastapi-auth-uploads
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
