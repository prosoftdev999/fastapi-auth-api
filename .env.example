APP_NAME=FastAPI Authentication API
APP_VERSION=0.2.0

# development | test | staging | production
ENVIRONMENT=development

DATABASE_URL=postgresql+psycopg2://fastapi_user:fastapi_password@localhost:5432/fastapi_auth

# Used for JWT blacklist (logout), single-use email-verification/password-reset
# tokens, and rate limiting.
REDIS_URL=redis://localhost:6379/0

# Generate a strong value for staging/production, e.g.: openssl rand -hex 32
# Required: >=16 chars always, >=32 chars and non-default when ENVIRONMENT=production
SECRET_KEY=replace-this-with-a-long-random-secret-key

ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-google-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME=FastAPI Authentication API

# Must be https:// when ENVIRONMENT=production
FRONTEND_URL=http://localhost:3000

# Comma-separated list, e.g.: https://app.example.com,https://admin.example.com
CORS_ORIGINS=http://localhost:3000

# Comma-separated list. Wildcard "*" is rejected when ENVIRONMENT=production
TRUSTED_HOSTS=*

# DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# OAuth providers (Authlib). All optional — a provider is only enabled once
# both its client id and secret are set. Callback URL to register with each
# provider: <your-host>/auth/oauth/<provider>/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=common

# S3-compatible object storage for file uploads. Optional — /files/* returns
# 503 until both access key vars are set. Leave S3_ENDPOINT_URL unset for
# real AWS; set it for MinIO/R2/Spaces/other S3-compatible providers.
# docker-compose.yml points these at the local MinIO service by default.
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET_NAME=fastapi-auth-uploads
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
